{
  "name": "simpletool-app-unified",
  "version": "2.4.1",
  "description": "Unified SimpleTool App - All tools in one Cloudflare Worker deployment",
  "type": "module",
  "scripts": {
    "build:css": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./styles/input.css -o ./dist/styles.css --minify",
    "build:fonts": "node scripts/download-fonts.js",
    "build:ui": "node scripts/build-ui.js",
    "build:vendor": "node scripts/build-vendor.js",
    "build:game-utils": "esbuild src/utils/game-utils.js --bundle --minify --outfile=dist/vendor/game-utils.min.js --format=iife --global-name=GameUtils",
    "build:routes": "node scripts/build-routes.js",
    "build:og": "node scripts/build-og-image.js",
    "build": "bun run build:fonts && bun run build:og && bun run build:routes && bun run build:css && bun run build:ui && bun run build:vendor && bun run build:game-utils",
    "dev": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:a11y": "playwright test tests/e2e/accessibility-audit.spec.js"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@sentry/cloudflare": "^10.38.0",
    "bcryptjs": "^2.4.3",
    "blueimp-md5": "^2.19.0",
    "dompurify": "^3.3.3",
    "js-yaml": "^5.0.0",
    "jsqr": "^1.4.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "node-forge": "^1.4.0",
    "pako": "^3.0.0",
    "qrcode": "^1.5.4",
    "railroad-diagrams": "^1.0.0",
    "to-json-schema": "^0.2.5",
    "toml": "^4.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260705.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.1",
    "baseline-browser-mapping": "^2.9.18",
    "esbuild": "^0.28.0",
    "lighthouse": "^13.0.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.2",
    "wrangler": "^4.77.0"
  },
  "keywords": [
    "cloudflare-workers",
    "tools",
    "password-generator",
    "caffeniate",
    "utility"
  ],
  "author": "SimpleTool App",
  "license": "MIT",
  "browserslist": [
    "defaults"
  ]
}
